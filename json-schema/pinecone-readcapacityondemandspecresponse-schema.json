{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/ReadCapacityOnDemandSpecResponse",
  "title": "On-demand",
  "example": {
    "mode": "OnDemand",
    "status": {
      "state": "Ready"
    }
  },
